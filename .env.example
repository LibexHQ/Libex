# Database — required
DB_NAME=libex
DB_USER=libex
DB_PASSWORD=your_secure_password

# DATABASE_URL is auto-constructed by docker-compose from DB_NAME, DB_USER, and DB_PASSWORD.
# Only set this manually if running outside of Docker.
# DATABASE_URL=postgresql+asyncpg://libex:your_secure_password@localhost:5432/libex

# Application
DEBUG=false
HOST=0.0.0.0
PORT=3333
DEFAULT_REGION=us

# Cache
CACHE_ENABLED=true
CACHE_TTL=86400

# Logging
LOG_RETENTION_DAYS=7  # 0 = infinite, N = keep N days of rotated logs

# Axiom (optional — leave blank to use stdout only)
AXIOM_TOKEN=
AXIOM_DATASET=libex

# Seeder (optional — disabled by default)
SEEDER_ENABLED=false
SEEDER_INTERVAL_HOURS=24
SEEDER_REQUEST_DELAY=1.0
SEEDER_REGIONS=us

# Proxy (optional — route Audible requests through a proxy)
AUDIBLE_PROXY_URL=

