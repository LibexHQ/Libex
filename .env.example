# ============================================================
# Libex Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================================
# Application
# ============================================================
DEBUG=false
HOST=0.0.0.0
PORT=3333

# ============================================================
# Database
# ============================================================
DB_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://libex:changeme@postgres:5432/libex

# ============================================================
# Cache
# ============================================================
CACHE_ENABLED=true
CACHE_TTL=86400

# ============================================================
# Audible
# ============================================================
DEFAULT_REGION=us

# ============================================================
# Axiom Logging (optional)
# Leave empty to disable - logs will go to stdout only
# Libex uses Axiom for structured logging if configured.
# See https://axiom.co for setup instructions.
# ============================================================
AXIOM_TOKEN=
AXIOM_DATASET=libex