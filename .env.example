# Database — required
DN_NAME=libex
DB_USER=libex
DB_PASSWORD=your_secure_password
DATABASE_URL=postgresql+asyncpg://libex:your_secure_password@postgres:5432/libex

# Application
DEBUG=false
HOST=0.0.0.0
PORT=3333
DEFAULT_REGION=us

# Cache
CACHE_ENABLED=true
CACHE_TTL=86400

# Logging
LOG_RETENTION_DAYS=7  # 0 = infinite, N = keep N days of rotated logs

# Axiom (optional — leave blank to use stdout only)
AXIOM_TOKEN=
AXIOM_DATASET=libex